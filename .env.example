# PostgreSQL Config (from base_infra)
DATABASE_URL=postgresql://chat_app:change_me_chat_secret@postgres:5432/zendb

# Redis Config (from base_infra)
REDIS_URL=redis://:change_me_redis_secret@redis:6379/1

# Webhook Auth
CONVERSATIONS_WEBHOOK_SECRET=your_webhook_secret_here

# Zendesk Conversations API Auth
SUNCO_KEY_ID=your_sunco_key_id
SUNCO_KEY_SECRET=your_sunco_key_secret

# Zendesk Tickets API
ZENDESK_SUBDOMAIN=kasikornbankgroup
ZENDESK_API_TOKEN=your_zendesk_api_token
ZENDESK_AGENT_GROUP_ID=your_target_group_id_for_handoff

# RAG Integration
RAG_BASE_URL=http://your-rag-service-url

# Flush Buffer Debounce (seconds)
FLUSH_BUFFER_DEBOUNCE_SECONDS=30

# Concurrency tuning
# API: WEB_CONCURRENCY uvicorn workers × DB_POOL_MAX_SIZE = total API DB connections
# Worker: replicas × WORKER_POOL_MAX_SIZE = total worker DB connections
#         replicas × WORKER_MAX_JOBS = max concurrent AI reply slots
WEB_CONCURRENCY=4
DB_POOL_MAX_SIZE=5
WORKER_POOL_MAX_SIZE=10
WORKER_MAX_JOBS=10

# App Environment
ENV=development

# OpenTelemetry (traces → Jaeger via infra base)
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317
